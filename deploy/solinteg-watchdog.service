[Unit]
Description=Solinteg dispatch-loop watchdog (one-shot safety check)
After=network-online.target

[Service]
Type=oneshot
User=solinteg
WorkingDirectory=/opt/solinteg/app
EnvironmentFile=/opt/solinteg/solinteg.env
ExecStart=/opt/solinteg/app/.venv/bin/python /opt/solinteg/app/scripts/services/watchdog.py
# Sandbox: whole FS read-only except /opt/solinteg (heartbeat/state files).
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/opt/solinteg
